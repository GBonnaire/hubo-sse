{
  "name": "@hubo/server",
  "version": "0.1.0",
  "description": "SSE hub multi-tenant auto-hébergé",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "hubo": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node --input-type=commonjs -e \"const fs=require('fs'),p='dist/cli/index.js';fs.writeFileSync(p,'#!/usr/bin/env node\\n'+fs.readFileSync(p,'utf8'))\"",
    "dev": "tsx watch src/cli/index.ts start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "sse",
    "server-sent-events",
    "hub",
    "multi-tenant"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.19.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.3",
    "uuidv7": "^1.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.4"
  }
}
