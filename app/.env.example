# Hubo — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# === Application ===
# PORT=3000                         # Port d'écoute (injecté automatiquement par Passenger)
# HUBO_LOG_LEVEL=info               # debug | info | warn | error

# === Base de données ===
DATABASE_URL=mysql://user:password@host:3306/hubo

# === Redis ===
# REDIS_URL=redis://localhost:6379

# === Optionnel ===
# HUBO_HTTPS_REDIRECT=false         # Redirection HTTP→HTTPS via x-forwarded-proto
# HUBO_ADMIN_TOKEN=change-me        # Token Bearer pour protéger /metrics
